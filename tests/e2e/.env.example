# E2E Test Environment Configuration
# Copy this file to tests/e2e/.env and fill in your API keys.
#
# The test script (test-dcp-cache.sh) runs opencode sessions against
# multiple providers to measure DCP's impact on token caching.
# Each provider below needs its API credentials configured.
#
# Required CLI tools: opencode, git, jq, lsof, fuser
#
# Usage:
#   cp tests/e2e/.env.example tests/e2e/.env
#   # Fill in your keys below
#   source tests/e2e/.env
#   npm run test:e2e

# =============================================================================
# opencode-go subscription (included in opencode-go plan)
# Model: opencode/kimi-k2.5-free
# Credentials: handled by opencode-go subscription config
# =============================================================================
# No additional env vars needed—configured via opencode.jsonc provider block.

# =============================================================================
# OpenAI
# Model: openai/gpt-5.2-codex
# =============================================================================
# OPENAI_API_KEY="sk-..."

# =============================================================================
# OpenRouter
# Model: openrouter/anthropic/claude-haiku-4.5
# =============================================================================
# OPENROUTER_API_KEY="sk-or-..."

# =============================================================================
# Kimi (Moonshot)
# Model: kimi-for-coding/k2p5
# =============================================================================
# KIMI_API_KEY="..."

# =============================================================================
# LLM Proxy (generic proxy for multiple backends)
# Models:
#   llm-proxy/cli_gemini-3-flash-high
#   llm-proxy/ant_gemini-3-flash-high
#   llm-proxy/claude-opus-4-5-thinking
# =============================================================================
# LLM_PROXY_API_KEY="..."
# LLM_PROXY_BASE_URL="https://your-proxy.example.com"

# =============================================================================
# Local proxy credentials (if using a different auth model)
# =============================================================================
# LLM_PROXY_CLI_GEMINI_API_KEY="..."
# LLM_PROXY_ANT_GEMINI_API_KEY="..."
# LLM_PROXY_OPUS_API_KEY="..."

# =============================================================================
# opencode Configuration
# =============================================================================
# The e2e test starts an opencode server on port 4096 by default.
# Override with --port or set:
# OPENCODE_E2E_PORT=4096

# =============================================================================
# Test behavior
# =============================================================================
# Run only specific provider(s) (comma-separated):
# OPENCODE_E2E_PROVIDERS="openai,openrouter-haiku"
